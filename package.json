{
  "name": "kv-sync",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "frontend",
    "shared",
    "functions"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" ",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npx wrangler pages dev frontend/out --kv KV_SYNC --binding PASSWORD=123456 --ip 0.0.0.0 --port 8080 --persist-to ./data",
    "build:client": "npm run build --prefix client",
    "build": "npm run build --prefix frontend",
    "ci-test": "node ./scripts/ci-test.js",
    "ci:static": "node ./scripts/ci-test.js static",
    "ci:integration": "node ./scripts/ci-test.js integration",
    "pack:client": "npm run pack:check --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "mocha": "^10.6.0",
    "wait-on": "^7.2.0",
    "wrangler": "^4.24.0"
  }
}
